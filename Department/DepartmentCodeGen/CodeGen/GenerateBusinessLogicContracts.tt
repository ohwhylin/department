<#@ template language="C#" hostspecific="true" #>
<#@ output extension=".generated.cs" #>
<#@ assembly name="System.Core" #>
<#@ import namespace="System" #>
<#@ import namespace="System.IO" #>
<#@ import namespace="System.Linq" #>
<#@ import namespace="System.Collections.Generic" #>

// <auto-generated />
// Marker file. Actual logic contracts are generated into /BusinessLogicsContracts/AutoGen/*.cs

<#
    var templateDir = Path.GetDirectoryName(Host.TemplateFile)!;
    var specsDir = Path.Combine(templateDir, "specs");

    var outputDir = Path.GetFullPath(Path.Combine(templateDir, "..", "BusinessLogicsContracts", "AutoGen"));
    Directory.CreateDirectory(outputDir);

    var yamlFiles = Directory.Exists(specsDir)
        ? Directory.GetFiles(specsDir, "*.yaml")
        : Array.Empty<string>();

    var entityNames = new List<string>();

    foreach (var file in yamlFiles)
    {
        var lines = File.ReadAllLines(file)
            .Select(l => l.Trim())
            .Where(l => !string.IsNullOrWhiteSpace(l) && !l.StartsWith("#"))
            .ToList();

        var name = ParseEntityName(lines);
        if (!string.IsNullOrWhiteSpace(name))
            entityNames.Add(name);
    }

    foreach (var entity in entityNames.Distinct())
    {
        var code = RenderLogicInterface(entity);
        var filePath = Path.Combine(outputDir, $"I{entity}Logic.cs");
        File.WriteAllText(filePath, code, System.Text.Encoding.UTF8);
    }

    string? ParseEntityName(List<string> lines)
    {
        bool inEntity = false;

        foreach (var line in lines)
        {
            if (line == "entity:")
            {
                inEntity = true;
                continue;
            }

            if (inEntity && line.StartsWith("name:"))
                return line.Substring("name:".Length).Trim();
        }

        return null;
    }

    string RenderLogicInterface(string entityName)
    {
        var sb = new System.Text.StringBuilder();

        sb.AppendLine("// <auto-generated />");
        sb.AppendLine("using System.Collections.Generic;");
        sb.AppendLine("using DepartmentContracts.BindingModels;");
        sb.AppendLine("using DepartmentContracts.SearchModels;");
        sb.AppendLine("using DepartmentContracts.ViewModels;");
        sb.AppendLine();
        sb.AppendLine("namespace DepartmentContracts.BusinessLogicsContracts");
        sb.AppendLine("{");
        sb.AppendLine($"    public interface I{entityName}Logic");
        sb.AppendLine("    {");
        sb.AppendLine($"        List<{entityName}ViewModel>? ReadList({entityName}SearchModel? model);");
        sb.AppendLine($"        {entityName}ViewModel? ReadElement({entityName}SearchModel model);");
        sb.AppendLine($"        bool Create({entityName}BindingModel model);");
        sb.AppendLine($"        bool Update({entityName}BindingModel model);");
        sb.AppendLine($"        bool Delete({entityName}BindingModel model);");
        sb.AppendLine("    }");
        sb.AppendLine("}");

        return sb.ToString();
    }
#>
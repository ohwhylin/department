        sb.AppendLine($"                ViewBag.{ep}List = APIClient.GetRequest<List<{e}ViewModel>>(\"api/{ep}/Get{e}List\");");
        foreach (var reference in references)
        {
            sb.AppendLine($"                ViewBag.{reference}sList = APIClient.GetRequest<List<{reference}ViewModel>>(\"api/{reference}s/Get{reference}List\");");
        }
        sb.AppendLine("                return View();");
        sb.AppendLine("            }");
        sb.AppendLine("            catch (Exception ex)");
        sb.AppendLine("            {");
        sb.AppendLine("                TempData[\"Error\"] = ex.Message;");

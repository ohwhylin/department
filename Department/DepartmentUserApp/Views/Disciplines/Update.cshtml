@model DepartmentContracts.BindingModels.DisciplineBindingModel
@using DepartmentDataModels.Enums
@using Newtonsoft.Json;
@{
    ViewData["Title"] = "DisciplineUpdate";
}
<header>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</header>
<style>
    .validation-summary-errors { color: #dc3545; margin-bottom: 15px; }
    .field-validation-error { color: #dc3545; font-size: 0.875em; }
    .input-validation-error { border-color: #dc3545; }
    .alert-danger { color: #721c24; background-color: #f8d7da; border-color: #f5c6cb; padding: .75rem 1.25rem; margin-bottom: 1rem; border: 1px solid transparent; border-radius: .25rem; }
</style>

<div class="text-center">
    <h2 class="display-4">Данные Discipline</h2>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form method="post">
    <div class="row">
        <div class="col-4">Discipline:</div>
        <div class="col-8">
            <select asp-for="Id" class="form-control" asp-items="@(new SelectList(@ViewBag.DisciplinesList, "Id", "Id"))"></select>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Discipline Block Id:</div>
        <div class="col-8">
            <select asp-for="DisciplineBlockId" class="form-control">
                @foreach (var item in ViewBag.DisciplineBlocksList)
                {
                    <option value="@item.Id">@item.Id</option>
                }
            </select>
            <span asp-validation-for="DisciplineBlockId" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Discipline Name:</div>
        <div class="col-8">
            <input asp-for="DisciplineName" class="form-control" />
            <span asp-validation-for="DisciplineName" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Discipline Short Name:</div>
        <div class="col-8">
            <input asp-for="DisciplineShortName" class="form-control" />
            <span asp-validation-for="DisciplineShortName" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Discipline Description:</div>
        <div class="col-8">
            <input asp-for="DisciplineDescription" class="form-control" />
            <span asp-validation-for="DisciplineDescription" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Discipline Block Blue Asterisk Name:</div>
        <div class="col-8">
            <input asp-for="DisciplineBlockBlueAsteriskName" class="form-control" />
            <span asp-validation-for="DisciplineBlockBlueAsteriskName" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-8"></div>
        <div class="col-4"><input type="submit" value="Сохранить" class="btn btn-primary" /></div>
    </div>
</form>

<script>
    $(document).ready(function () {
        $('#Id').change(function () {
            var selectedId = $(this).val();
            var entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.DisciplinesList));
            var selected = entities.find(d => d.Id == selectedId);
            if (selected) {
                $('#DisciplineBlockId').val(selected.DisciplineBlockId);
                $('#DisciplineName').val(selected.DisciplineName);
                $('#DisciplineShortName').val(selected.DisciplineShortName);
                $('#DisciplineDescription').val(selected.DisciplineDescription);
                $('#DisciplineBlockBlueAsteriskName').val(selected.DisciplineBlockBlueAsteriskName);
            }
        });
        $('#Id').trigger('change');
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

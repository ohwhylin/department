@model DepartmentContracts.BindingModels.StudentBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentDataModels.Enums
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Изменение Student";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Изменение Student</h2>
        <a class="btn btn-sm btn-light" asp-controller="Students" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Id" class="form-label">Запись</label>
                <select asp-for="Id" class="form-select" asp-items='@(new SelectList(ViewBag.StudentsList, "Id", "Id"))'></select>
            </div>
            <div class="mb-3">
                <label asp-for="StudentGroupId" class="form-label">Student Group Id</label>
                <select asp-for="StudentGroupId" class="form-select">
                    <option value="">Выберите значение</option>
                    @foreach (var item in ViewBag.StudentGroupsList)
                    {
                        <option value="@item.Id">@GetDisplayValue(item)</option>
                    }
                </select>
                <span asp-validation-for="StudentGroupId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="NumberOfBook" class="form-label">Number Of Book</label>
                <input asp-for="NumberOfBook" class="form-control" />
                <span asp-validation-for="NumberOfBook" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="FirstName" class="form-label">First Name</label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LastName" class="form-label">Last Name</label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Patronymic" class="form-label">Patronymic</label>
                <input asp-for="Patronymic" class="form-control" />
                <span asp-validation-for="Patronymic" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="StudentState" class="form-label">Student State</label>
                <select asp-for="StudentState" class="form-select" asp-items="Html.GetEnumSelectList<StudentState>()"></select>
                <span asp-validation-for="StudentState" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IsSteward" class="form-label">Is Steward</label>
                <div class="form-check">
                    <input asp-for="IsSteward" class="form-check-input" />
                </div>
                <span asp-validation-for="IsSteward" class="text-danger"></span>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="Students" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.StudentsList));
        const idSelect = document.getElementById('Id');
        function fillFields() {
            const selected = entities.find(x => x.Id == idSelect.value);
            if (!selected) return;
            const elStudentGroupId = document.getElementById('StudentGroupId');
            if (elStudentGroupId) elStudentGroupId.value = selected.StudentGroupId ?? '';
            const elNumberOfBook = document.getElementById('NumberOfBook');
            if (elNumberOfBook) elNumberOfBook.value = selected.NumberOfBook ?? '';
            const elFirstName = document.getElementById('FirstName');
            if (elFirstName) elFirstName.value = selected.FirstName ?? '';
            const elLastName = document.getElementById('LastName');
            if (elLastName) elLastName.value = selected.LastName ?? '';
            const elPatronymic = document.getElementById('Patronymic');
            if (elPatronymic) elPatronymic.value = selected.Patronymic ?? '';
            const elEmail = document.getElementById('Email');
            if (elEmail) elEmail.value = selected.Email ?? '';
            const elStudentState = document.getElementById('StudentState');
            if (elStudentState) elStudentState.value = selected.StudentState ?? '';
            const elDescription = document.getElementById('Description');
            if (elDescription) elDescription.value = selected.Description ?? '';
            const elIsSteward = document.getElementById('IsSteward');
            if (elIsSteward) elIsSteward.value = selected.IsSteward ?? '';
        }
        if (idSelect) {
            idSelect.addEventListener('change', fillFields);
            fillFields();
        }
    });
</script>

@functions {
    public string GetDisplayValue(object item)
    {
        var type = item.GetType();
        foreach (var propName in new[] { "Name", "Title", "GroupName", "DisciplineName", "OrderNumber", "DepartmentPostTitle", "StudyPostTitle", "Cipher", "ShortName" })
        {
            var prop = type.GetProperty(propName);
            var value = prop?.GetValue(item)?.ToString();
            if (!string.IsNullOrWhiteSpace(value)) return value;
        }
        var firstName = type.GetProperty("FirstName")?.GetValue(item)?.ToString();
        var lastName = type.GetProperty("LastName")?.GetValue(item)?.ToString();
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return ($"{lastName} {firstName}").Trim();
        return type.GetProperty("Id")?.GetValue(item)?.ToString() ?? string.Empty;
    }
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

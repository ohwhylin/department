@model DepartmentContracts.BindingModels.StudentBindingModel
@using DepartmentDataModels.Enums
@using Newtonsoft.Json;
@{
    ViewData["Title"] = "StudentUpdate";
}
<header>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</header>
<style>
    .validation-summary-errors { color: #dc3545; margin-bottom: 15px; }
    .field-validation-error { color: #dc3545; font-size: 0.875em; }
    .input-validation-error { border-color: #dc3545; }
    .alert-danger { color: #721c24; background-color: #f8d7da; border-color: #f5c6cb; padding: .75rem 1.25rem; margin-bottom: 1rem; border: 1px solid transparent; border-radius: .25rem; }
</style>

<div class="text-center">
    <h2 class="display-4">Данные Student</h2>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form method="post">
    <div class="row">
        <div class="col-4">Student:</div>
        <div class="col-8">
            <select asp-for="Id" class="form-control" asp-items="@(new SelectList(@ViewBag.StudentsList, "Id", "Id"))"></select>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Student Group Id:</div>
        <div class="col-8">
            <select asp-for="StudentGroupId" class="form-control">
                @foreach (var item in ViewBag.StudentGroupsList)
                {
                    <option value="@item.Id">@item.Id</option>
                }
            </select>
            <span asp-validation-for="StudentGroupId" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Number Of Book:</div>
        <div class="col-8">
            <input asp-for="NumberOfBook" class="form-control" />
            <span asp-validation-for="NumberOfBook" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">First Name:</div>
        <div class="col-8">
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Last Name:</div>
        <div class="col-8">
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Patronymic:</div>
        <div class="col-8">
            <input asp-for="Patronymic" class="form-control" />
            <span asp-validation-for="Patronymic" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Email:</div>
        <div class="col-8">
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Student State:</div>
        <div class="col-8">
            <select asp-for="StudentState" class="form-control" asp-items="Html.GetEnumSelectList<StudentState>()"></select>
            <span asp-validation-for="StudentState" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Description:</div>
        <div class="col-8">
            <input asp-for="Description" class="form-control" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Is Steward:</div>
        <div class="col-8">
            <div class="form-check">
                <input asp-for="IsSteward" class="form-check-input" />
            </div>
            <span asp-validation-for="IsSteward" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-8"></div>
        <div class="col-4"><input type="submit" value="Сохранить" class="btn btn-primary" /></div>
    </div>
</form>

<script>
    $(document).ready(function () {
        $('#Id').change(function () {
            var selectedId = $(this).val();
            var entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.StudentsList));
            var selected = entities.find(d => d.Id == selectedId);
            if (selected) {
                $('#StudentGroupId').val(selected.StudentGroupId);
                $('#NumberOfBook').val(selected.NumberOfBook);
                $('#FirstName').val(selected.FirstName);
                $('#LastName').val(selected.LastName);
                $('#Patronymic').val(selected.Patronymic);
                $('#Email').val(selected.Email);
                $('#StudentState').val(selected.StudentState);
                $('#Description').val(selected.Description);
                $('#IsSteward').val(selected.IsSteward);
            }
        });
        $('#Id').trigger('change');
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

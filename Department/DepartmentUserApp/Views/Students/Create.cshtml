@model DepartmentContracts.BindingModels.StudentBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Создание Student";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Добавление Student</h2>
        <a class="btn btn-sm btn-light" asp-controller="Students" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="accordion" id="createAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#createMainBlock">
                            Основные данные
                        </button>
                    </h2>
                    <div id="createMainBlock" class="accordion-collapse collapse show">
                        <div class="accordion-body">
                            <div class="mb-3">
                                <label asp-for="StudentGroupId" class="form-label">Student Group Id</label>
                                <select asp-for="StudentGroupId" class="form-select">
                                    <option value="">Выберите значение</option>
                                    @foreach (var item in ViewBag.StudentGroupsList)
                                    {
                                        <option value="@item.Id">@GetDisplayValue(item)</option>
                                    }
                                </select>
                                <span asp-validation-for="StudentGroupId" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="NumberOfBook" class="form-label">Number Of Book</label>
                                <input asp-for="NumberOfBook" class="form-control" />
                                <span asp-validation-for="NumberOfBook" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="FirstName" class="form-label">First Name</label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="LastName" class="form-label">Last Name</label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Patronymic" class="form-label">Patronymic</label>
                                <input asp-for="Patronymic" class="form-control" />
                                <span asp-validation-for="Patronymic" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Email" class="form-label">Email</label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="StudentState" class="form-label">Student State</label>
                                <select asp-for="StudentState" class="form-select" asp-items="Html.GetEnumSelectList<StudentState>()"></select>
                                <span asp-validation-for="StudentState" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Description" class="form-label">Description</label>
                                <input asp-for="Description" class="form-control" />
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="IsSteward" class="form-label">Is Steward</label>
                                <div class="form-check">
                                    <input asp-for="IsSteward" class="form-check-input" />
                                </div>
                                <span asp-validation-for="IsSteward" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="Students" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

@functions {
    public string GetDisplayValue(object item)
    {
        var type = item.GetType();
        foreach (var propName in new[] { "Name", "Title", "GroupName", "DisciplineName", "OrderNumber", "DepartmentPostTitle", "StudyPostTitle", "Cipher", "ShortName" })
        {
            var prop = type.GetProperty(propName);
            var value = prop?.GetValue(item)?.ToString();
            if (!string.IsNullOrWhiteSpace(value)) return value;
        }
        var firstName = type.GetProperty("FirstName")?.GetValue(item)?.ToString();
        var lastName = type.GetProperty("LastName")?.GetValue(item)?.ToString();
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return ($"{lastName} {firstName}").Trim();
        return type.GetProperty("Id")?.GetValue(item)?.ToString() ?? string.Empty;
    }
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

@model DepartmentContracts.ViewModels.StudentViewModel
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Подробнее о Student";
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о Student</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-light" asp-controller="Students" asp-action="Update">Изменить</a>
            <a class="btn btn-sm btn-light" asp-controller="Students" asp-action="List">К списку</a>
        </div>
    </div>
    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Id
            </dt>
            <dd class="col-sm-8">
                @Model.Id
            </dd>
            <dt class="col-sm-4 text-muted">
                StudentGroup
            </dt>
            <dd class="col-sm-8">
                @Model.StudentGroup
            </dd>
            <dt class="col-sm-4 text-muted">
                Number Of Book
            </dt>
            <dd class="col-sm-8">
                @Model.NumberOfBook
            </dd>
            <dt class="col-sm-4 text-muted">
                First Name
            </dt>
            <dd class="col-sm-8">
                @Model.FirstName
            </dd>
            <dt class="col-sm-4 text-muted">
                Last Name
            </dt>
            <dd class="col-sm-8">
                @Model.LastName
            </dd>
            <dt class="col-sm-4 text-muted">
                Patronymic
            </dt>
            <dd class="col-sm-8">
                @Model.Patronymic
            </dd>
            <dt class="col-sm-4 text-muted">
                Email
            </dt>
            <dd class="col-sm-8">
                @Model.Email
            </dd>
            <dt class="col-sm-4 text-muted">
                Student State
            </dt>
            <dd class="col-sm-8">
                @Model.StudentState
            </dd>
            <dt class="col-sm-4 text-muted">
                Description
            </dt>
            <dd class="col-sm-8">
                @Model.Description
            </dd>
            <dt class="col-sm-4 text-muted">
                Is Steward
            </dt>
            <dd class="col-sm-8">
                @Model.IsSteward
            </dd>
        </dl>
    </div>
</div>

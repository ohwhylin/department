@model DepartmentContracts.BindingModels.StudentGroupBindingModel
@using DepartmentDataModels.Enums
@using Newtonsoft.Json;
@{
    ViewData["Title"] = "StudentGroupUpdate";
}
<header>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</header>
<style>
    .validation-summary-errors { color: #dc3545; margin-bottom: 15px; }
    .field-validation-error { color: #dc3545; font-size: 0.875em; }
    .input-validation-error { border-color: #dc3545; }
    .alert-danger { color: #721c24; background-color: #f8d7da; border-color: #f5c6cb; padding: .75rem 1.25rem; margin-bottom: 1rem; border: 1px solid transparent; border-radius: .25rem; }
</style>

<div class="text-center">
    <h2 class="display-4">Данные StudentGroup</h2>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form method="post">
    <div class="row">
        <div class="col-4">StudentGroup:</div>
        <div class="col-8">
            <select asp-for="Id" class="form-control" asp-items="@(new SelectList(@ViewBag.StudentGroupsList, "Id", "Id"))"></select>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Education Direction Id:</div>
        <div class="col-8">
            <select asp-for="EducationDirectionId" class="form-control">
                @foreach (var item in ViewBag.EducationDirectionsList)
                {
                    <option value="@item.Id">@item.Id</option>
                }
            </select>
            <span asp-validation-for="EducationDirectionId" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Curator Id:</div>
        <div class="col-8">
            <select asp-for="CuratorId" class="form-control">
                @foreach (var item in ViewBag.LecturersList)
                {
                    <option value="@item.Id">@item.Id</option>
                }
            </select>
            <span asp-validation-for="CuratorId" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Group Name:</div>
        <div class="col-8">
            <input asp-for="GroupName" class="form-control" />
            <span asp-validation-for="GroupName" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Course:</div>
        <div class="col-8">
            <select asp-for="Course" class="form-control" asp-items="Html.GetEnumSelectList<AcademicCourse>()"></select>
            <span asp-validation-for="Course" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-8"></div>
        <div class="col-4"><input type="submit" value="Сохранить" class="btn btn-primary" /></div>
    </div>
</form>

<script>
    $(document).ready(function () {
        $('#Id').change(function () {
            var selectedId = $(this).val();
            var entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.StudentGroupsList));
            var selected = entities.find(d => d.Id == selectedId);
            if (selected) {
                $('#EducationDirectionId').val(selected.EducationDirectionId);
                $('#CuratorId').val(selected.CuratorId);
                $('#GroupName').val(selected.GroupName);
                $('#Course').val(selected.Course);
            }
        });
        $('#Id').trigger('change');
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model DepartmentContracts.BindingModels.ClassroomBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Создание Classroom";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Добавление Classroom</h2>
        <a class="btn btn-sm btn-light" asp-controller="Classrooms" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="accordion" id="createAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#createMainBlock">
                            Основные данные
                        </button>
                    </h2>
                    <div id="createMainBlock" class="accordion-collapse collapse show">
                        <div class="accordion-body">
                            <div class="mb-3">
                                <label asp-for="Number" class="form-label">Number</label>
                                <input asp-for="Number" class="form-control" />
                                <span asp-validation-for="Number" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="ClassroomType" class="form-label">Classroom Type</label>
                                <select asp-for="ClassroomType" class="form-select" asp-items="Html.GetEnumSelectList<ClassroomTypes>()"></select>
                                <span asp-validation-for="ClassroomType" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Capacity" class="form-label">Capacity</label>
                                <input asp-for="Capacity" class="form-control" />
                                <span asp-validation-for="Capacity" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="NotUseInSchedule" class="form-label">Not Use In Schedule</label>
                                <div class="form-check">
                                    <input asp-for="NotUseInSchedule" class="form-check-input" />
                                </div>
                                <span asp-validation-for="NotUseInSchedule" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="Classrooms" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

@functions {
    public string GetDisplayValue(object item)
    {
        var type = item.GetType();
        foreach (var propName in new[] { "Name", "Title", "GroupName", "DisciplineName", "OrderNumber", "DepartmentPostTitle", "StudyPostTitle", "Cipher", "ShortName" })
        {
            var prop = type.GetProperty(propName);
            var value = prop?.GetValue(item)?.ToString();
            if (!string.IsNullOrWhiteSpace(value)) return value;
        }
        var firstName = type.GetProperty("FirstName")?.GetValue(item)?.ToString();
        var lastName = type.GetProperty("LastName")?.GetValue(item)?.ToString();
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return ($"{lastName} {firstName}").Trim();
        return type.GetProperty("Id")?.GetValue(item)?.ToString() ?? string.Empty;
    }
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

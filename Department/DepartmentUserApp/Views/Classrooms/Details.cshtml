@model DepartmentContracts.ViewModels.ClassroomViewModel
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Подробнее о Classroom";
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о Classroom</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-light" asp-controller="Classrooms" asp-action="Update">Изменить</a>
            <a class="btn btn-sm btn-light" asp-controller="Classrooms" asp-action="List">К списку</a>
        </div>
    </div>
    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Id
            </dt>
            <dd class="col-sm-8">
                @Model.Id
            </dd>
            <dt class="col-sm-4 text-muted">
                Number
            </dt>
            <dd class="col-sm-8">
                @Model.Number
            </dd>
            <dt class="col-sm-4 text-muted">
                Classroom Type
            </dt>
            <dd class="col-sm-8">
                @Model.ClassroomType
            </dd>
            <dt class="col-sm-4 text-muted">
                Capacity
            </dt>
            <dd class="col-sm-8">
                @Model.Capacity
            </dd>
            <dt class="col-sm-4 text-muted">
                Not Use In Schedule
            </dt>
            <dd class="col-sm-8">
                @Model.NotUseInSchedule
            </dd>
        </dl>
    </div>
</div>

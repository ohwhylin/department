@model DepartmentContracts.ViewModels.LecturerDepartmentPostViewModel
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Подробнее о LecturerDepartmentPost";
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о LecturerDepartmentPost</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-light" asp-controller="LecturerDepartmentPosts" asp-action="Update">Изменить</a>
            <a class="btn btn-sm btn-light" asp-controller="LecturerDepartmentPosts" asp-action="List">К списку</a>
        </div>
    </div>
    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Id
            </dt>
            <dd class="col-sm-8">
                @Model.Id
            </dd>
            <dt class="col-sm-4 text-muted">
                Department Post Title
            </dt>
            <dd class="col-sm-8">
                @Model.DepartmentPostTitle
            </dd>
            <dt class="col-sm-4 text-muted">
                Order
            </dt>
            <dd class="col-sm-8">
                @Model.Order
            </dd>
        </dl>
    </div>
</div>

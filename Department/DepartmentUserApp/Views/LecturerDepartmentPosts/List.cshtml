@{
    ViewData["Title"] = "LecturerDepartmentPosts";
}

<div class="list-shell">
    <div class="list-head">
        <div>
            <h2 class="list-title">Список LecturerDepartmentPosts</h2>
            <div class="list-sub">Управление сущностью LecturerDepartmentPost</div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-app-primary" asp-controller="LecturerDepartmentPosts" asp-action="Create">Добавить</a>
        </div>
    </div>

    @if (ViewBag.LecturerDepartmentPostsList != null)
    {
        @foreach (var item in ViewBag.LecturerDepartmentPostsList)
        {
            <div class="entity-row">
                <div class="entity-accent"></div>
                <div class="entity-content">
                    <div class="entity-main">
                        <h5 class="entity-title">@item.DepartmentPostTitle</h5>
                        <div class="entity-meta">
                            <span class="meta-chip">Id: @item.Id</span>
                            <span class="meta-chip">@item.DepartmentPostTitle</span>
                            <span class="meta-chip">@item.Order</span>
                        </div>
                    </div>
                </div>
                <div class="entity-actions">
                    <div class="actions-stack">
                        <a class="btn btn-sm btn-app-outline" asp-controller="LecturerDepartmentPosts" asp-action="Details" asp-route-id="@item.Id">Подробнее</a>
                        <a class="btn btn-sm btn-app-outline" asp-controller="LecturerDepartmentPosts" asp-action="Update">Изменить</a>
                        <a class="btn btn-sm btn-app-outline" asp-controller="LecturerDepartmentPosts" asp-action="Delete">Удалить</a>
                    </div>
                </div>
            </div>
        }
    }
</div>

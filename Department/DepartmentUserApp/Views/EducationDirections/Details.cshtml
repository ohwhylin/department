@model DepartmentContracts.ViewModels.EducationDirectionViewModel
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Подробнее о EducationDirection";
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о EducationDirection</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-light" asp-controller="EducationDirections" asp-action="Update">Изменить</a>
            <a class="btn btn-sm btn-light" asp-controller="EducationDirections" asp-action="List">К списку</a>
        </div>
    </div>
    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Id
            </dt>
            <dd class="col-sm-8">
                @Model.Id
            </dd>
            <dt class="col-sm-4 text-muted">
                Cipher
            </dt>
            <dd class="col-sm-8">
                @Model.Cipher
            </dd>
            <dt class="col-sm-4 text-muted">
                Short Name
            </dt>
            <dd class="col-sm-8">
                @Model.ShortName
            </dd>
            <dt class="col-sm-4 text-muted">
                Title
            </dt>
            <dd class="col-sm-8">
                @Model.Title
            </dd>
            <dt class="col-sm-4 text-muted">
                Qualification
            </dt>
            <dd class="col-sm-8">
                @Model.Qualification
            </dd>
            <dt class="col-sm-4 text-muted">
                Profile
            </dt>
            <dd class="col-sm-8">
                @Model.Profile
            </dd>
            <dt class="col-sm-4 text-muted">
                Description
            </dt>
            <dd class="col-sm-8">
                @Model.Description
            </dd>
        </dl>
    </div>
</div>

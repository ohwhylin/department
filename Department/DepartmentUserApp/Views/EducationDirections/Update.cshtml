@model DepartmentContracts.BindingModels.EducationDirectionBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentDataModels.Enums
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Изменение EducationDirection";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Изменение EducationDirection</h2>
        <a class="btn btn-sm btn-light" asp-controller="EducationDirections" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Id" class="form-label">Запись</label>
                <select asp-for="Id" class="form-select" asp-items='@(new SelectList(ViewBag.EducationDirectionsList, "Id", "Id"))'></select>
            </div>
            <div class="mb-3">
                <label asp-for="Cipher" class="form-label">Cipher</label>
                <input asp-for="Cipher" class="form-control" />
                <span asp-validation-for="Cipher" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ShortName" class="form-label">Short Name</label>
                <input asp-for="ShortName" class="form-control" />
                <span asp-validation-for="ShortName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Title" class="form-label">Title</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Qualification" class="form-label">Qualification</label>
                <select asp-for="Qualification" class="form-select" asp-items="Html.GetEnumSelectList<EducationDirectionQualification>()"></select>
                <span asp-validation-for="Qualification" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Profile" class="form-label">Profile</label>
                <input asp-for="Profile" class="form-control" />
                <span asp-validation-for="Profile" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="EducationDirections" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.EducationDirectionsList));
        const idSelect = document.getElementById('Id');
        function fillFields() {
            const selected = entities.find(x => x.Id == idSelect.value);
            if (!selected) return;
            const elCipher = document.getElementById('Cipher');
            if (elCipher) elCipher.value = selected.Cipher ?? '';
            const elShortName = document.getElementById('ShortName');
            if (elShortName) elShortName.value = selected.ShortName ?? '';
            const elTitle = document.getElementById('Title');
            if (elTitle) elTitle.value = selected.Title ?? '';
            const elQualification = document.getElementById('Qualification');
            if (elQualification) elQualification.value = selected.Qualification ?? '';
            const elProfile = document.getElementById('Profile');
            if (elProfile) elProfile.value = selected.Profile ?? '';
            const elDescription = document.getElementById('Description');
            if (elDescription) elDescription.value = selected.Description ?? '';
        }
        if (idSelect) {
            idSelect.addEventListener('change', fillFields);
            fillFields();
        }
    });
</script>

@functions {
    public string GetDisplayValue(object item)
    {
        var type = item.GetType();
        foreach (var propName in new[] { "Name", "Title", "GroupName", "DisciplineName", "OrderNumber", "DepartmentPostTitle", "StudyPostTitle", "Cipher", "ShortName" })
        {
            var prop = type.GetProperty(propName);
            var value = prop?.GetValue(item)?.ToString();
            if (!string.IsNullOrWhiteSpace(value)) return value;
        }
        var firstName = type.GetProperty("FirstName")?.GetValue(item)?.ToString();
        var lastName = type.GetProperty("LastName")?.GetValue(item)?.ToString();
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return ($"{lastName} {firstName}").Trim();
        return type.GetProperty("Id")?.GetValue(item)?.ToString() ?? string.Empty;
    }
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

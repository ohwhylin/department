<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Университет</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .navbar-custom {
            background-color: #595766;
        }

        .navbar-brand {
            font-weight: bold;
        }

        .nav-link {
            color: white !important;
        }

            .nav-link:hover {
                text-decoration: underline;
            }

        main {
            margin-top: 20px;
        }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
            <div class="container">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    Университет
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="EducationDirections" asp-action="List">
                                Направления
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="StudentGroups" asp-action="List">
                                Группы
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Students" asp-action="List">
                                Студенты
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Lecturers" asp-action="List">
                                Преподаватели
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Disciplines" asp-action="List">
                                Дисциплины
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="AcademicPlans" asp-action="List">
                                Учебные планы
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="StudentOrders" asp-action="List">
                                Приказы
                            </a>
                        </li>

                    </ul>

                </div>

            </div>
        </nav>
    </header>

    <div class="container">

        <main role="main" class="pb-3">

            @RenderBody()

        </main>

    </div>

    @RenderSection("Styles", required: false)
    @RenderSection("Scripts", required: false)

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
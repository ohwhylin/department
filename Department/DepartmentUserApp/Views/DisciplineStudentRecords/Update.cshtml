@model DepartmentContracts.BindingModels.DisciplineStudentRecordBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentDataModels.Enums
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Изменение DisciplineStudentRecord";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Изменение DisciplineStudentRecord</h2>
        <a class="btn btn-sm btn-light" asp-controller="DisciplineStudentRecords" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Id" class="form-label">Запись</label>
                <select asp-for="Id" class="form-select" asp-items='@(new SelectList(ViewBag.DisciplineStudentRecordsList, "Id", "Id"))'></select>
            </div>
            <div class="mb-3">
                <label asp-for="DisciplineId" class="form-label">Discipline Id</label>
                <select asp-for="DisciplineId" class="form-select">
                    <option value="">Выберите значение</option>
                    @foreach (var item in ViewBag.DisciplinesList)
                    {
                        <option value="@item.Id">@GetDisplayValue(item)</option>
                    }
                </select>
                <span asp-validation-for="DisciplineId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="StudentId" class="form-label">Student Id</label>
                <select asp-for="StudentId" class="form-select">
                    <option value="">Выберите значение</option>
                    @foreach (var item in ViewBag.StudentsList)
                    {
                        <option value="@item.Id">@GetDisplayValue(item)</option>
                    }
                </select>
                <span asp-validation-for="StudentId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Semester" class="form-label">Semester</label>
                <select asp-for="Semester" class="form-select" asp-items="Html.GetEnumSelectList<Semesters>()"></select>
                <span asp-validation-for="Semester" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Variant" class="form-label">Variant</label>
                <input asp-for="Variant" class="form-control" />
                <span asp-validation-for="Variant" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SubGroup" class="form-label">Sub Group</label>
                <input asp-for="SubGroup" class="form-control" />
                <span asp-validation-for="SubGroup" class="text-danger"></span>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="DisciplineStudentRecords" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.DisciplineStudentRecordsList));
        const idSelect = document.getElementById('Id');
        function fillFields() {
            const selected = entities.find(x => x.Id == idSelect.value);
            if (!selected) return;
            const elDisciplineId = document.getElementById('DisciplineId');
            if (elDisciplineId) elDisciplineId.value = selected.DisciplineId ?? '';
            const elStudentId = document.getElementById('StudentId');
            if (elStudentId) elStudentId.value = selected.StudentId ?? '';
            const elSemester = document.getElementById('Semester');
            if (elSemester) elSemester.value = selected.Semester ?? '';
            const elVariant = document.getElementById('Variant');
            if (elVariant) elVariant.value = selected.Variant ?? '';
            const elSubGroup = document.getElementById('SubGroup');
            if (elSubGroup) elSubGroup.value = selected.SubGroup ?? '';
        }
        if (idSelect) {
            idSelect.addEventListener('change', fillFields);
            fillFields();
        }
    });
</script>

@functions {
    public string GetDisplayValue(object item)
    {
        var type = item.GetType();
        foreach (var propName in new[] { "Name", "Title", "GroupName", "DisciplineName", "OrderNumber", "DepartmentPostTitle", "StudyPostTitle", "Cipher", "ShortName" })
        {
            var prop = type.GetProperty(propName);
            var value = prop?.GetValue(item)?.ToString();
            if (!string.IsNullOrWhiteSpace(value)) return value;
        }
        var firstName = type.GetProperty("FirstName")?.GetValue(item)?.ToString();
        var lastName = type.GetProperty("LastName")?.GetValue(item)?.ToString();
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return ($"{lastName} {firstName}").Trim();
        return type.GetProperty("Id")?.GetValue(item)?.ToString() ?? string.Empty;
    }
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

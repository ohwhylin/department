@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Удаление AcademicPlanRecord";
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Удаление AcademicPlanRecord</h2>
        <a class="btn btn-sm btn-light" asp-controller="AcademicPlanRecords" asp-action="List">К списку</a>
    </div>
    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        <form method="post">
            <div class="mb-3">
                <label for="id" class="form-label">Выберите запись</label>
                <select id="id" name="id" class="form-select" asp-items='@(new SelectList(ViewBag.AcademicPlanRecordsList, "Id", "Id"))'></select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Удалить</button>
                <a class="btn btn-app-outline" asp-controller="AcademicPlanRecords" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

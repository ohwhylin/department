@model DepartmentContracts.ViewModels.AcademicPlanViewModel
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Подробнее о AcademicPlan";
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о AcademicPlan</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-light" asp-controller="AcademicPlans" asp-action="Update">Изменить</a>
            <a class="btn btn-sm btn-light" asp-controller="AcademicPlans" asp-action="List">К списку</a>
        </div>
    </div>
    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Id
            </dt>
            <dd class="col-sm-8">
                @Model.Id
            </dd>
            <dt class="col-sm-4 text-muted">
                EducationDirection
            </dt>
            <dd class="col-sm-8">
                @Model.EducationDirection
            </dd>
            <dt class="col-sm-4 text-muted">
                Academic Courses
            </dt>
            <dd class="col-sm-8">
                @Model.AcademicCourses
            </dd>
            <dt class="col-sm-4 text-muted">
                Year
            </dt>
            <dd class="col-sm-8">
                @Model.Year
            </dd>
        </dl>
    </div>
</div>

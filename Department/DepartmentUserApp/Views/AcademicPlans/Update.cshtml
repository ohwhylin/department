@model DepartmentContracts.BindingModels.AcademicPlanBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentDataModels.Enums
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Изменение AcademicPlan";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Изменение AcademicPlan</h2>
        <a class="btn btn-sm btn-light" asp-controller="AcademicPlans" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Id" class="form-label">Запись</label>
                <select asp-for="Id" class="form-select" asp-items='@(new SelectList(ViewBag.AcademicPlansList, "Id", "Id"))'></select>
            </div>
            <div class="mb-3">
                <label asp-for="EducationDirectionId" class="form-label">Education Direction Id</label>
                <select asp-for="EducationDirectionId" class="form-select">
                    <option value="">Выберите значение</option>
                    @foreach (var item in ViewBag.EducationDirectionsList)
                    {
                        <option value="@item.Id">@GetDisplayValue(item)</option>
                    }
                </select>
                <span asp-validation-for="EducationDirectionId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="AcademicCourses" class="form-label">Academic Courses</label>
                <select asp-for="AcademicCourses" class="form-select" asp-items="Html.GetEnumSelectList<AcademicCourse>()"></select>
                <span asp-validation-for="AcademicCourses" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Year" class="form-label">Year</label>
                <input asp-for="Year" class="form-control" />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="AcademicPlans" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.AcademicPlansList));
        const idSelect = document.getElementById('Id');
        function fillFields() {
            const selected = entities.find(x => x.Id == idSelect.value);
            if (!selected) return;
            const elEducationDirectionId = document.getElementById('EducationDirectionId');
            if (elEducationDirectionId) elEducationDirectionId.value = selected.EducationDirectionId ?? '';
            const elAcademicCourses = document.getElementById('AcademicCourses');
            if (elAcademicCourses) elAcademicCourses.value = selected.AcademicCourses ?? '';
            const elYear = document.getElementById('Year');
            if (elYear) elYear.value = selected.Year ?? '';
        }
        if (idSelect) {
            idSelect.addEventListener('change', fillFields);
            fillFields();
        }
    });
</script>

@functions {
    public string GetDisplayValue(object item)
    {
        var type = item.GetType();
        foreach (var propName in new[] { "Name", "Title", "GroupName", "DisciplineName", "OrderNumber", "DepartmentPostTitle", "StudyPostTitle", "Cipher", "ShortName" })
        {
            var prop = type.GetProperty(propName);
            var value = prop?.GetValue(item)?.ToString();
            if (!string.IsNullOrWhiteSpace(value)) return value;
        }
        var firstName = type.GetProperty("FirstName")?.GetValue(item)?.ToString();
        var lastName = type.GetProperty("LastName")?.GetValue(item)?.ToString();
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return ($"{lastName} {firstName}").Trim();
        return type.GetProperty("Id")?.GetValue(item)?.ToString() ?? string.Empty;
    }
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

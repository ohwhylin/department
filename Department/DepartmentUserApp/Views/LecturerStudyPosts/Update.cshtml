@model DepartmentContracts.BindingModels.LecturerStudyPostBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentDataModels.Enums
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Изменение LecturerStudyPost";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Изменение LecturerStudyPost</h2>
        <a class="btn btn-sm btn-light" asp-controller="LecturerStudyPosts" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Id" class="form-label">Запись</label>
                <select asp-for="Id" class="form-select" asp-items='@(new SelectList(ViewBag.LecturerStudyPostsList, "Id", "Id"))'></select>
            </div>
            <div class="mb-3">
                <label asp-for="StudyPostTitle" class="form-label">Study Post Title</label>
                <input asp-for="StudyPostTitle" class="form-control" />
                <span asp-validation-for="StudyPostTitle" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Hours" class="form-label">Hours</label>
                <input asp-for="Hours" class="form-control" />
                <span asp-validation-for="Hours" class="text-danger"></span>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="LecturerStudyPosts" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.LecturerStudyPostsList));
        const idSelect = document.getElementById('Id');
        function fillFields() {
            const selected = entities.find(x => x.Id == idSelect.value);
            if (!selected) return;
            const elStudyPostTitle = document.getElementById('StudyPostTitle');
            if (elStudyPostTitle) elStudyPostTitle.value = selected.StudyPostTitle ?? '';
            const elHours = document.getElementById('Hours');
            if (elHours) elHours.value = selected.Hours ?? '';
        }
        if (idSelect) {
            idSelect.addEventListener('change', fillFields);
            fillFields();
        }
    });
</script>

@functions {
    public string GetDisplayValue(object item)
    {
        var type = item.GetType();
        foreach (var propName in new[] { "Name", "Title", "GroupName", "DisciplineName", "OrderNumber", "DepartmentPostTitle", "StudyPostTitle", "Cipher", "ShortName" })
        {
            var prop = type.GetProperty(propName);
            var value = prop?.GetValue(item)?.ToString();
            if (!string.IsNullOrWhiteSpace(value)) return value;
        }
        var firstName = type.GetProperty("FirstName")?.GetValue(item)?.ToString();
        var lastName = type.GetProperty("LastName")?.GetValue(item)?.ToString();
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return ($"{lastName} {firstName}").Trim();
        return type.GetProperty("Id")?.GetValue(item)?.ToString() ?? string.Empty;
    }
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

@model DepartmentContracts.ViewModels.LecturerStudyPostViewModel
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Подробнее о LecturerStudyPost";
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о LecturerStudyPost</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-light" asp-controller="LecturerStudyPosts" asp-action="Update">Изменить</a>
            <a class="btn btn-sm btn-light" asp-controller="LecturerStudyPosts" asp-action="List">К списку</a>
        </div>
    </div>
    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Id
            </dt>
            <dd class="col-sm-8">
                @Model.Id
            </dd>
            <dt class="col-sm-4 text-muted">
                Study Post Title
            </dt>
            <dd class="col-sm-8">
                @Model.StudyPostTitle
            </dd>
            <dt class="col-sm-4 text-muted">
                Hours
            </dt>
            <dd class="col-sm-8">
                @Model.Hours
            </dd>
        </dl>
    </div>
</div>

@model DepartmentContracts.BindingModels.StudentOrderBlockStudentBindingModel
@using DepartmentDataModels.Enums
@using Newtonsoft.Json;
@{
    ViewData["Title"] = "StudentOrderBlockStudentUpdate";
}
<header>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</header>
<style>
    .validation-summary-errors { color: #dc3545; margin-bottom: 15px; }
    .field-validation-error { color: #dc3545; font-size: 0.875em; }
    .input-validation-error { border-color: #dc3545; }
    .alert-danger { color: #721c24; background-color: #f8d7da; border-color: #f5c6cb; padding: .75rem 1.25rem; margin-bottom: 1rem; border: 1px solid transparent; border-radius: .25rem; }
</style>

<div class="text-center">
    <h2 class="display-4">Данные StudentOrderBlockStudent</h2>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form method="post">
    <div class="row">
        <div class="col-4">StudentOrderBlockStudent:</div>
        <div class="col-8">
            <select asp-for="Id" class="form-control" asp-items="@(new SelectList(@ViewBag.StudentOrderBlockStudentsList, "Id", "Id"))"></select>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Student Order Block Id:</div>
        <div class="col-8">
            <select asp-for="StudentOrderBlockId" class="form-control">
                @foreach (var item in ViewBag.StudentOrderBlocksList)
                {
                    <option value="@item.Id">@item.Id</option>
                }
            </select>
            <span asp-validation-for="StudentOrderBlockId" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Student Id:</div>
        <div class="col-8">
            <select asp-for="StudentId" class="form-control">
                @foreach (var item in ViewBag.StudentsList)
                {
                    <option value="@item.Id">@item.Id</option>
                }
            </select>
            <span asp-validation-for="StudentId" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Student Group From Id:</div>
        <div class="col-8">
            <select asp-for="StudentGroupFromId" class="form-control">
                @foreach (var item in ViewBag.StudentGroupsList)
                {
                    <option value="@item.Id">@item.Id</option>
                }
            </select>
            <span asp-validation-for="StudentGroupFromId" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Student Group To Id:</div>
        <div class="col-8">
            <select asp-for="StudentGroupToId" class="form-control">
                @foreach (var item in ViewBag.StudentGroupsList)
                {
                    <option value="@item.Id">@item.Id</option>
                }
            </select>
            <span asp-validation-for="StudentGroupToId" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-8"></div>
        <div class="col-4"><input type="submit" value="Сохранить" class="btn btn-primary" /></div>
    </div>
</form>

<script>
    $(document).ready(function () {
        $('#Id').change(function () {
            var selectedId = $(this).val();
            var entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.StudentOrderBlockStudentsList));
            var selected = entities.find(d => d.Id == selectedId);
            if (selected) {
                $('#StudentOrderBlockId').val(selected.StudentOrderBlockId);
                $('#StudentId').val(selected.StudentId);
                $('#StudentGroupFromId').val(selected.StudentGroupFromId);
                $('#StudentGroupToId').val(selected.StudentGroupToId);
            }
        });
        $('#Id').trigger('change');
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

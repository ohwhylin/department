@model DepartmentContracts.ViewModels.StudentOrderBlockStudentViewModel
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Подробнее о StudentOrderBlockStudent";
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о StudentOrderBlockStudent</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-light" asp-controller="StudentOrderBlockStudents" asp-action="Update">Изменить</a>
            <a class="btn btn-sm btn-light" asp-controller="StudentOrderBlockStudents" asp-action="List">К списку</a>
        </div>
    </div>
    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Id
            </dt>
            <dd class="col-sm-8">
                @Model.Id
            </dd>
            <dt class="col-sm-4 text-muted">
                StudentOrderBlock
            </dt>
            <dd class="col-sm-8">
                @Model.StudentOrderBlock
            </dd>
            <dt class="col-sm-4 text-muted">
                Student
            </dt>
            <dd class="col-sm-8">
                @Model.Student
            </dd>
            <dt class="col-sm-4 text-muted">
                StudentGroup
            </dt>
            <dd class="col-sm-8">
                @Model.StudentGroupFrom
            </dd>
            <dt class="col-sm-4 text-muted">
                StudentGroup
            </dt>
            <dd class="col-sm-8">
                @Model.StudentGroupTo
            </dd>
        </dl>
    </div>
</div>

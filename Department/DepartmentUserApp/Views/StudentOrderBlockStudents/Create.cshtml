@model DepartmentContracts.BindingModels.StudentOrderBlockStudentBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Создание StudentOrderBlockStudent";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Добавление StudentOrderBlockStudent</h2>
        <a class="btn btn-sm btn-light" asp-controller="StudentOrderBlockStudents" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="accordion" id="createAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#createMainBlock">
                            Основные данные
                        </button>
                    </h2>
                    <div id="createMainBlock" class="accordion-collapse collapse show">
                        <div class="accordion-body">
                            <div class="mb-3">
                                <label asp-for="StudentOrderBlockId" class="form-label">Student Order Block Id</label>
                                <select asp-for="StudentOrderBlockId" class="form-select">
                                    <option value="">Выберите значение</option>
                                    @foreach (var item in ViewBag.StudentOrderBlocksList)
                                    {
                                        <option value="@item.Id">@GetDisplayValue(item)</option>
                                    }
                                </select>
                                <span asp-validation-for="StudentOrderBlockId" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="StudentId" class="form-label">Student Id</label>
                                <select asp-for="StudentId" class="form-select">
                                    <option value="">Выберите значение</option>
                                    @foreach (var item in ViewBag.StudentsList)
                                    {
                                        <option value="@item.Id">@GetDisplayValue(item)</option>
                                    }
                                </select>
                                <span asp-validation-for="StudentId" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="StudentGroupFromId" class="form-label">Student Group From Id</label>
                                <select asp-for="StudentGroupFromId" class="form-select">
                                    <option value="">Выберите значение</option>
                                    @foreach (var item in ViewBag.StudentGroupsList)
                                    {
                                        <option value="@item.Id">@GetDisplayValue(item)</option>
                                    }
                                </select>
                                <span asp-validation-for="StudentGroupFromId" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="StudentGroupToId" class="form-label">Student Group To Id</label>
                                <select asp-for="StudentGroupToId" class="form-select">
                                    <option value="">Выберите значение</option>
                                    @foreach (var item in ViewBag.StudentGroupsList)
                                    {
                                        <option value="@item.Id">@GetDisplayValue(item)</option>
                                    }
                                </select>
                                <span asp-validation-for="StudentGroupToId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="StudentOrderBlockStudents" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

@functions {
    public string GetDisplayValue(object item)
    {
        var type = item.GetType();
        foreach (var propName in new[] { "Name", "Title", "GroupName", "DisciplineName", "OrderNumber", "DepartmentPostTitle", "StudyPostTitle", "Cipher", "ShortName" })
        {
            var prop = type.GetProperty(propName);
            var value = prop?.GetValue(item)?.ToString();
            if (!string.IsNullOrWhiteSpace(value)) return value;
        }
        var firstName = type.GetProperty("FirstName")?.GetValue(item)?.ToString();
        var lastName = type.GetProperty("LastName")?.GetValue(item)?.ToString();
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return ($"{lastName} {firstName}").Trim();
        return type.GetProperty("Id")?.GetValue(item)?.ToString() ?? string.Empty;
    }
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

@model DepartmentContracts.BindingModels.LecturerBindingModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using DepartmentDataModels.Enums
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Изменение Lecturer";
}

<div class="form-shell">
    <div class="form-shell__header">
        <h2 class="form-shell__title">Изменение Lecturer</h2>
        <a class="btn btn-sm btn-light" asp-controller="Lecturers" asp-action="List">К списку</a>
    </div>

    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Id" class="form-label">Запись</label>
                <select asp-for="Id" class="form-select" asp-items='@(new SelectList(ViewBag.LecturersList, "Id", "Id"))'></select>
            </div>
            <div class="mb-3">
                <label asp-for="LecturerStudyPostId" class="form-label">Lecturer Study Post Id</label>
                <select asp-for="LecturerStudyPostId" class="form-select">
                    <option value="">Выберите значение</option>
                    @foreach (var item in ViewBag.LecturerStudyPostsList)
                    {
                        <option value="@item.Id">@GetDisplayValue(item)</option>
                    }
                </select>
                <span asp-validation-for="LecturerStudyPostId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LecturerDepartmentPostId" class="form-label">Lecturer Department Post Id</label>
                <select asp-for="LecturerDepartmentPostId" class="form-select">
                    <option value="">Выберите значение</option>
                    @foreach (var item in ViewBag.LecturerDepartmentPostsList)
                    {
                        <option value="@item.Id">@GetDisplayValue(item)</option>
                    }
                </select>
                <span asp-validation-for="LecturerDepartmentPostId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="FirstName" class="form-label">First Name</label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LastName" class="form-label">Last Name</label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Patronymic" class="form-label">Patronymic</label>
                <input asp-for="Patronymic" class="form-control" />
                <span asp-validation-for="Patronymic" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Abbreviation" class="form-label">Abbreviation</label>
                <input asp-for="Abbreviation" class="form-control" />
                <span asp-validation-for="Abbreviation" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DateBirth" class="form-label">Date Birth</label>
                <input asp-for="DateBirth" class="form-control" />
                <span asp-validation-for="DateBirth" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label">Address</label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="MobileNumber" class="form-label">Mobile Number</label>
                <input asp-for="MobileNumber" class="form-control" />
                <span asp-validation-for="MobileNumber" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="HomeNumber" class="form-label">Home Number</label>
                <input asp-for="HomeNumber" class="form-control" />
                <span asp-validation-for="HomeNumber" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Rank" class="form-label">Rank</label>
                <select asp-for="Rank" class="form-select" asp-items="Html.GetEnumSelectList<Rank>()"></select>
                <span asp-validation-for="Rank" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Rank2" class="form-label">Rank2</label>
                <select asp-for="Rank2" class="form-select" asp-items="Html.GetEnumSelectList<Rank2>()"></select>
                <span asp-validation-for="Rank2" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="OnlyForPrivate" class="form-label">Only For Private</label>
                <div class="form-check">
                    <input asp-for="OnlyForPrivate" class="form-check-input" />
                </div>
                <span asp-validation-for="OnlyForPrivate" class="text-danger"></span>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-app-primary">Сохранить</button>
                <a class="btn btn-app-outline" asp-controller="Lecturers" asp-action="List">Отмена</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.LecturersList));
        const idSelect = document.getElementById('Id');
        function fillFields() {
            const selected = entities.find(x => x.Id == idSelect.value);
            if (!selected) return;
            const elLecturerStudyPostId = document.getElementById('LecturerStudyPostId');
            if (elLecturerStudyPostId) elLecturerStudyPostId.value = selected.LecturerStudyPostId ?? '';
            const elLecturerDepartmentPostId = document.getElementById('LecturerDepartmentPostId');
            if (elLecturerDepartmentPostId) elLecturerDepartmentPostId.value = selected.LecturerDepartmentPostId ?? '';
            const elFirstName = document.getElementById('FirstName');
            if (elFirstName) elFirstName.value = selected.FirstName ?? '';
            const elLastName = document.getElementById('LastName');
            if (elLastName) elLastName.value = selected.LastName ?? '';
            const elPatronymic = document.getElementById('Patronymic');
            if (elPatronymic) elPatronymic.value = selected.Patronymic ?? '';
            const elAbbreviation = document.getElementById('Abbreviation');
            if (elAbbreviation) elAbbreviation.value = selected.Abbreviation ?? '';
            const elDateBirth = document.getElementById('DateBirth');
            if (elDateBirth) elDateBirth.value = selected.DateBirth ?? '';
            const elAddress = document.getElementById('Address');
            if (elAddress) elAddress.value = selected.Address ?? '';
            const elEmail = document.getElementById('Email');
            if (elEmail) elEmail.value = selected.Email ?? '';
            const elMobileNumber = document.getElementById('MobileNumber');
            if (elMobileNumber) elMobileNumber.value = selected.MobileNumber ?? '';
            const elHomeNumber = document.getElementById('HomeNumber');
            if (elHomeNumber) elHomeNumber.value = selected.HomeNumber ?? '';
            const elRank = document.getElementById('Rank');
            if (elRank) elRank.value = selected.Rank ?? '';
            const elRank2 = document.getElementById('Rank2');
            if (elRank2) elRank2.value = selected.Rank2 ?? '';
            const elDescription = document.getElementById('Description');
            if (elDescription) elDescription.value = selected.Description ?? '';
            const elOnlyForPrivate = document.getElementById('OnlyForPrivate');
            if (elOnlyForPrivate) elOnlyForPrivate.value = selected.OnlyForPrivate ?? '';
        }
        if (idSelect) {
            idSelect.addEventListener('change', fillFields);
            fillFields();
        }
    });
</script>

@functions {
    public string GetDisplayValue(object item)
    {
        var type = item.GetType();
        foreach (var propName in new[] { "Name", "Title", "GroupName", "DisciplineName", "OrderNumber", "DepartmentPostTitle", "StudyPostTitle", "Cipher", "ShortName" })
        {
            var prop = type.GetProperty(propName);
            var value = prop?.GetValue(item)?.ToString();
            if (!string.IsNullOrWhiteSpace(value)) return value;
        }
        var firstName = type.GetProperty("FirstName")?.GetValue(item)?.ToString();
        var lastName = type.GetProperty("LastName")?.GetValue(item)?.ToString();
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return ($"{lastName} {firstName}").Trim();
        return type.GetProperty("Id")?.GetValue(item)?.ToString() ?? string.Empty;
    }
}
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

@model DepartmentContracts.BindingModels.DisciplineBlockBindingModel
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "DisciplineBlockCreate";
}
<div class="text-center">
    <h2 class="display-4">Добавление DisciplineBlock</h2>
</div>
<style>
    .row { margin-top: 10px; }
    .validation-summary-errors { color: #dc3545; margin-bottom: 15px; }
    .field-validation-error { color: #dc3545; font-size: 0.875em; }
    .input-validation-error { border-color: #dc3545; }
    .alert-danger { color: #721c24; background-color: #f8d7da; border-color: #f5c6cb; padding: .75rem 1.25rem; margin-bottom: 1rem; border: 1px solid transparent; border-radius: .25rem; }
</style>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@functions {
    public string GetDisplayText(object item)
    {
        var type = item.GetType();
        var idProp = type.GetProperty("Id");
        var firstName = type.GetProperty("FirstName")?.GetValue(item)?.ToString();
        var lastName = type.GetProperty("LastName")?.GetValue(item)?.ToString();
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return ($"{lastName} {firstName}").Trim();
        foreach (var propName in new[] { "Name", "Title", "Number", "ShortName", "Cipher", "OrderNumber", "DepartmentPostTitle", "StudyPostTitle", "GroupName", "DisciplineName" })
        {
            var prop = type.GetProperty(propName);
            var value = prop?.GetValue(item)?.ToString();
            if (!string.IsNullOrWhiteSpace(value)) return value;
        }
        return idProp?.GetValue(item)?.ToString() ?? string.Empty;
    }
}

<form method="post">
    <div class="row">
        <div class="col-4">Title:</div>
        <div class="col-8">
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Discipline Block Blue Asterisk Name:</div>
        <div class="col-8">
            <input asp-for="DisciplineBlockBlueAsteriskName" class="form-control" />
            <span asp-validation-for="DisciplineBlockBlueAsteriskName" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Discipline Block Use For Grouping:</div>
        <div class="col-8">
            <div class="form-check">
                <input asp-for="DisciplineBlockUseForGrouping" class="form-check-input" />
            </div>
            <span asp-validation-for="DisciplineBlockUseForGrouping" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Discipline Block Order:</div>
        <div class="col-8">
            <input asp-for="DisciplineBlockOrder" class="form-control" />
            <span asp-validation-for="DisciplineBlockOrder" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-8"></div>
        <div class="col-4">
            <input type="submit" value="Добавить" class="btn btn-primary" />
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

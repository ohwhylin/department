@model DepartmentContracts.ViewModels.StudentOrderViewModel
@using DepartmentDataModels.Enums
@{
    ViewData["Title"] = "Подробнее о StudentOrder";
}

<div class="app-card">
    <div class="app-card-header">
        <h2 class="app-card-title">Подробнее о StudentOrder</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-light" asp-controller="StudentOrders" asp-action="Update">Изменить</a>
            <a class="btn btn-sm btn-light" asp-controller="StudentOrders" asp-action="List">К списку</a>
        </div>
    </div>
    <div class="p-3">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">
                Id
            </dt>
            <dd class="col-sm-8">
                @Model.Id
            </dd>
            <dt class="col-sm-4 text-muted">
                Order Number
            </dt>
            <dd class="col-sm-8">
                @Model.OrderNumber
            </dd>
            <dt class="col-sm-4 text-muted">
                Student Order Type
            </dt>
            <dd class="col-sm-8">
                @Model.StudentOrderType
            </dd>
        </dl>
    </div>
</div>

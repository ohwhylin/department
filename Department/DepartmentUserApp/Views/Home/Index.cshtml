@{
    ViewData["Title"] = "Главная";
}

<div class="app-card mb-4">
    <div class="app-card-header">
        <h2 class="app-card-title">Главная страница</h2>
    </div>
    <div class="p-3">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mb-3">
                @TempData["Error"]
            </div>
        }

        <p class="mb-0">
            Добро пожаловать в модуль кафедрального портала.
            Выберите нужный раздел в верхнем меню для работы с данными.
        </p>
    </div>
</div>

<div class="row g-3">

    <div class="col-md-6 col-xl-3">
        <div class="app-card h-100">
            <div class="app-card-header">
                <h5 class="app-card-title">Направления</h5>
            </div>
            <div class="p-3">
                <div class="display-6 fw-bold">@ViewBag.EducationDirectionCount</div>
                <div class="hint mb-3">Количество направлений подготовки</div>
                <a class="btn btn-app-outline btn-sm" asp-controller="EducationDirections" asp-action="List">
                    Перейти
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="app-card h-100">
            <div class="app-card-header">
                <h5 class="app-card-title">Преподаватели</h5>
            </div>
            <div class="p-3">
                <div class="display-6 fw-bold">@ViewBag.LecturerCount</div>
                <div class="hint mb-3">Количество преподавателей</div>
                <a class="btn btn-app-outline btn-sm" asp-controller="Lecturers" asp-action="List">
                    Перейти
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="app-card h-100">
            <div class="app-card-header">
                <h5 class="app-card-title">Студенты</h5>
            </div>
            <div class="p-3">
                <div class="display-6 fw-bold">@ViewBag.StudentCount</div>
                <div class="hint mb-3">Количество студентов</div>
                <a class="btn btn-app-outline btn-sm" asp-controller="Students" asp-action="List">
                    Перейти
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="app-card h-100">
            <div class="app-card-header">
                <h5 class="app-card-title">Группы</h5>
            </div>
            <div class="p-3">
                <div class="display-6 fw-bold">@ViewBag.StudentGroupCount</div>
                <div class="hint mb-3">Количество учебных групп</div>
                <a class="btn btn-app-outline btn-sm" asp-controller="StudentGroups" asp-action="List">
                    Перейти
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="app-card h-100">
            <div class="app-card-header">
                <h5 class="app-card-title">Дисциплины</h5>
            </div>
            <div class="p-3">
                <div class="display-6 fw-bold">@ViewBag.DisciplineCount</div>
                <div class="hint mb-3">Количество дисциплин</div>
                <a class="btn btn-app-outline btn-sm" asp-controller="Disciplines" asp-action="List">
                    Перейти
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="app-card h-100">
            <div class="app-card-header">
                <h5 class="app-card-title">Учебные планы</h5>
            </div>
            <div class="p-3">
                <div class="display-6 fw-bold">@ViewBag.AcademicPlanCount</div>
                <div class="hint mb-3">Количество учебных планов</div>
                <a class="btn btn-app-outline btn-sm" asp-controller="AcademicPlans" asp-action="List">
                    Перейти
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="app-card h-100">
            <div class="app-card-header">
                <h5 class="app-card-title">Приказы</h5>
            </div>
            <div class="p-3">
                <div class="display-6 fw-bold">@ViewBag.StudentOrderCount</div>
                <div class="hint mb-3">Количество приказов</div>
                <a class="btn btn-app-outline btn-sm" asp-controller="StudentOrders" asp-action="List">
                    Перейти
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="app-card h-100">
            <div class="app-card-header">
                <h5 class="app-card-title">Аудитории</h5>
            </div>
            <div class="p-3">
                <div class="display-6 fw-bold">@ViewBag.ClassroomCount</div>
                <div class="hint mb-3">Количество аудиторий</div>
                <a class="btn btn-app-outline btn-sm" asp-controller="Classrooms" asp-action="List">
                    Перейти
                </a>
            </div>
        </div>
    </div>

</div>
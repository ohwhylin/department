@model DepartmentContracts.BindingModels.StudentOrderBlockBindingModel
@using DepartmentDataModels.Enums
@using Newtonsoft.Json;
@{
    ViewData["Title"] = "StudentOrderBlockUpdate";
}
<header>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</header>
<style>
    .validation-summary-errors { color: #dc3545; margin-bottom: 15px; }
    .field-validation-error { color: #dc3545; font-size: 0.875em; }
    .input-validation-error { border-color: #dc3545; }
    .alert-danger { color: #721c24; background-color: #f8d7da; border-color: #f5c6cb; padding: .75rem 1.25rem; margin-bottom: 1rem; border: 1px solid transparent; border-radius: .25rem; }
</style>

<div class="text-center">
    <h2 class="display-4">Данные StudentOrderBlock</h2>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form method="post">
    <div class="row">
        <div class="col-4">StudentOrderBlock:</div>
        <div class="col-8">
            <select asp-for="Id" class="form-control" asp-items="@(new SelectList(@ViewBag.StudentOrderBlocksList, "Id", "Id"))"></select>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Student Order Id:</div>
        <div class="col-8">
            <select asp-for="StudentOrderId" class="form-control">
                @foreach (var item in ViewBag.StudentOrdersList)
                {
                    <option value="@item.Id">@item.Id</option>
                }
            </select>
            <span asp-validation-for="StudentOrderId" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Education Direction Id:</div>
        <div class="col-8">
            <select asp-for="EducationDirectionId" class="form-control">
                @foreach (var item in ViewBag.EducationDirectionsList)
                {
                    <option value="@item.Id">@item.Id</option>
                }
            </select>
            <span asp-validation-for="EducationDirectionId" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-4">Student Order Type:</div>
        <div class="col-8">
            <select asp-for="StudentOrderType" class="form-control" asp-items="Html.GetEnumSelectList<StudentOrderType>()"></select>
            <span asp-validation-for="StudentOrderType" class="text-danger"></span>
        </div>
    </div>
    <div class="row">
        <div class="col-8"></div>
        <div class="col-4"><input type="submit" value="Сохранить" class="btn btn-primary" /></div>
    </div>
</form>

<script>
    $(document).ready(function () {
        $('#Id').change(function () {
            var selectedId = $(this).val();
            var entities = @Html.Raw(JsonConvert.SerializeObject(ViewBag.StudentOrderBlocksList));
            var selected = entities.find(d => d.Id == selectedId);
            if (selected) {
                $('#StudentOrderId').val(selected.StudentOrderId);
                $('#EducationDirectionId').val(selected.EducationDirectionId);
                $('#StudentOrderType').val(selected.StudentOrderType);
            }
        });
        $('#Id').trigger('change');
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
